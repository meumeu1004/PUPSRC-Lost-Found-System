<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 10; -fx-border-radius: 10;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SettingsController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-weight: bold;" text="CHANGE PASSWORD" textFill="#710912">
                    <font><Font size="22.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;" textFill="#710912">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
            </children>
        </HBox>

        <Separator />

        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="35.0" />
                <ColumnConstraints percentWidth="65.0" />
            </columnConstraints>

            <children>
                <!-- Current Password -->
                <Label text="Current Password:" textFill="#5b5b5b" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <PasswordField fx:id="currentPasswordField" promptText="Enter current password" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- New Password -->
                <Label text="New Password:" textFill="#5b5b5b" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <PasswordField fx:id="newPasswordField" promptText="Enter new password" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Confirm New Password -->
                <Label text="Confirm New Password:" textFill="#5b5b5b" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <!-- Password Requirements -->
        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
            <padding>
                <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
            </padding>
            <children>
                <Label text="Password Requirements:" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                    <font><Font size="12.0" /></font>
                </Label>
                <Label text="• At least 6 characters" textFill="#5b5b5b">
                    <font><Font size="11.0" /></font>
                </Label>
                <Label text="• Must contain at least one number" textFill="#5b5b5b">
                    <font><Font size="11.0" /></font>
                </Label>
                <Label text="• Must contain at least one letter" textFill="#5b5b5b">
                    <font><Font size="11.0" /></font>
                </Label>
            </children>
        </VBox>

        <!-- Buttons -->
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button onAction="#handleClose" style="-fx-background-color: #A5A5A5; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="CANCEL" />
                <Button fx:id="saveButton" onAction="#handleSave" style="-fx-background-color: #710912; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="SAVE CHANGES" />
            </children>
        </HBox>
    </children>
</VBox>
