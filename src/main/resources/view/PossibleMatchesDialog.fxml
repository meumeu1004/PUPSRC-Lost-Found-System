<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="760.0" spacing="12.0"
      style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 5; -fx-border-radius: 5;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PossibleMatchesController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="16.0"/></padding>
    <children>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="POSSIBLE MATCHES" textFill="#710912" style="-fx-font-weight: bold;">
                <font><Font size="20.0"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    textFill="#710912">
                <font><Font name="System Bold" size="18.0"/></font>
            </Button>
        </HBox>

        <Separator/>

        <!-- Result count label -->
        <Label fx:id="resultCountLabel" textFill="#5b5b5b" text="Searching..."/>

        <!-- Table -->
        <TableView fx:id="matchTable" prefHeight="380.0" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="scoreCol"    text="Match %"   prefWidth="80"/>
                <TableColumn fx:id="idCol"       text="ID"        prefWidth="60"/>
                <TableColumn fx:id="nameCol"     text="Item Name" prefWidth="180"/>
                <TableColumn fx:id="categoryCol" text="Category"  prefWidth="120"/>
                <TableColumn fx:id="colorCol"    text="Color"     prefWidth="100"/>
                <TableColumn fx:id="dateCol"     text="Date"      prefWidth="100"/>
                <TableColumn fx:id="statusCol"   text="Status"    prefWidth="90"/>
                <TableColumn fx:id="actionCol"   text=""          prefWidth="70"/>
            </columns>
        </TableView>

        <!-- No results label (hidden by default) -->
        <Label fx:id="noResultsLabel" text="No possible matching records were found."
               textFill="#5b5b5b" visible="false" managed="false"
               style="-fx-font-style: italic; -fx-font-size: 13px;"/>

        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT">
            <Button text="Close" onAction="#handleClose"
                    style="-fx-background-color: #710912; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 18;"/>
        </HBox>

    </children>
</VBox>