<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 10; -fx-border-radius: 10;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InfoDialogController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="titleLabel" style="-fx-font-weight: bold; -fx-font-size: 24px;" text="About Us" textFill="#710912">
                    <font><Font size="22.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <Separator />

        <ScrollPane fitToWidth="true" prefHeight="500.0" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="15.0">
                    <children>
                        <Label fx:id="contentLabel" wrapText="true" textFill="#5b5b5b" style="-fx-font-size: 14px; -fx-padding: 10;" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Separator />

        <Button onAction="#handleClose" style="-fx-background-color: #710912; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 30 10 30;" text="CLOSE" />
    </children>
</VBox>