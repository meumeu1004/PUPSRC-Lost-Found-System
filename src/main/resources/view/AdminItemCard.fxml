<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="220.0" prefWidth="220.0" style="-fx-background-color: #A9A9A9; -fx-background-radius: 12;" styleClass="item-card" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminItemCardController">
    <children>
        <StackPane fx:id="imageContainer" VBox.vgrow="ALWAYS">
            <children>
                <Label fx:id="iconLabel" text="?" textFill="WHITE" StackPane.alignment="CENTER">
                    <font><Font size="80.0" /></font>
                </Label>
                <ImageView fx:id="itemImage" fitHeight="140.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" visible="false" StackPane.alignment="CENTER" />
            </children>
        </StackPane>
        <VBox spacing="5.0" style="-fx-background-color: #710912; -fx-background-radius: 0 0 12 12;">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></padding>
            <children>
                <Label fx:id="itemName" style="-fx-font-weight: bold;" text="ITEM NAME" textFill="WHITE" />
                <Label fx:id="itemDate" text="Date" textFill="#eeeeee"><font><Font size="11.0" /></font></Label>
            </children>
        </VBox>
    </children>
</VBox>
