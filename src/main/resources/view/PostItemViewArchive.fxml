<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="660.0" spacing="0.0"
      style="-fx-background-color: #F7F7F7; -fx-border-color: #888888; -fx-border-width: 3;
             -fx-background-radius: 5; -fx-border-radius: 5;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PostItemViewArchiveController">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <children>

        <!-- ── Header ── -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label fx:id="titleLabel" text="ITEM DETAILS (ARCHIVED)" textFill="#555555"
                   style="-fx-font-weight: bold;">
                <font><Font size="22.0"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    textFill="#555555">
                <font><Font name="System Bold" size="18.0"/></font>
            </Button>
        </HBox>

        <Separator>
            <VBox.margin><Insets bottom="12.0" top="8.0"/></VBox.margin>
        </Separator>

        <!-- ── Scrollable Content ── -->
        <ScrollPane fitToWidth="true" prefHeight="460.0"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="16.0" style="-fx-background-color: transparent;">
                    <padding><Insets right="4.0"/></padding>

                    <!-- ── Item Information ── -->
                    <VBox spacing="10.0">
                        <Label text="Item Information" textFill="#555555"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Separator/>

                        <GridPane hgap="12.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Item Name" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="itemNameValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Category" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="categoryValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Color" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="colorValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Type" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="itemTypeValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label fx:id="itemDateLabel" text="Date Lost" textFill="#888888"
                                   style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="itemDateValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Status" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <Label fx:id="itemStatusValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        </GridPane>

                        <Label text="Description" textFill="#888888" style="-fx-font-size: 12px;"/>
                        <Label fx:id="descriptionValue" text="—" textFill="#2a2a2a"
                               wrapText="true" style="-fx-font-size: 13px;"/>
                    </VBox>

                    <!-- ── Reporter / Finder Information ── -->
                    <VBox spacing="10.0">
                        <Label fx:id="reporterSectionLabel" text="Reporter Information"
                               textFill="#555555"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Separator/>

                        <GridPane hgap="12.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Name" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="reporterNameValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Contact" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="contactValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Email" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="emailValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- ── Record Information ── -->
                    <VBox spacing="10.0">
                        <Label text="Record Information" textFill="#555555"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Separator/>

                        <GridPane hgap="12.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Date Reported" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="dateReportedValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Last Updated" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="lastUpdatedValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- ── Archive Info section (with inline Edit button) ── -->
                    <VBox spacing="10.0">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Archive Information" textFill="#555555"
                                   style="-fx-font-weight: bold; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="editArchiveInfoButton"
                                    onAction="#handleEditArchiveInfo"
                                    text="Edit"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #888888;
                                           -fx-font-size: 11px;
                                           -fx-cursor: hand;
                                           -fx-underline: true;
                                           -fx-padding: 0;"/>
                        </HBox>
                        <Separator/>

                        <GridPane hgap="12.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Reason" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="archiveReasonValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Archived On" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="archivedAtValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- ── Claimant Info section (found items only, with inline Edit) ── -->
                    <VBox fx:id="claimantSection" spacing="10.0" managed="false" visible="false">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Claimant Information" textFill="#555555"
                                   style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="editClaimInfoButton"
                                    onAction="#handleEditClaimInfo"
                                    text="Edit"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #888888;
                                           -fx-font-size: 11px;
                                           -fx-cursor: hand;
                                           -fx-underline: true;
                                           -fx-padding: 0;"
                                    managed="false" visible="false"/>
                        </HBox>
                        <Separator/>

                        <GridPane hgap="12.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Claimed By" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="claimantNameValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Student ID" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="studentIdValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Contact" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="claimantContactValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Email" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="claimantEmailValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Claim Date" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="claimDateValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Verified By" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <Label fx:id="verifiedByValue" text="—" textFill="#2a2a2a"
                                   style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                            <Label text="Remarks" textFill="#888888" style="-fx-font-size: 12px;"
                                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <Label fx:id="remarksValue" text="—" textFill="#2a2a2a"
                                   wrapText="true" style="-fx-font-size: 13px;"
                                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- ── Image ── -->
                    <VBox spacing="8.0" alignment="CENTER"
                          style="-fx-border-color: #CCCCCC; -fx-border-radius: 6;
                                 -fx-border-style: dashed; -fx-background-color: #F0F0F0;
                                 -fx-background-radius: 6;">
                        <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
                        <Label text="Item Image" textFill="#888888"
                               style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label fx:id="imagePlaceholderLabel" text="📷  No image provided"
                               textFill="#aaaaaa"
                               style="-fx-font-size: 12px; -fx-font-style: italic;"/>
                        <ImageView fx:id="previewImageView"
                                   fitHeight="180.0" fitWidth="320.0"
                                   preserveRatio="true" visible="false"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <Separator>
            <VBox.margin><Insets bottom="12.0" top="12.0"/></VBox.margin>
        </Separator>

        <!-- ── Bottom Action Buttons ── -->
        <HBox alignment="CENTER_RIGHT" spacing="8.0">
            <Button fx:id="restoreButton" onAction="#handleRestore"
                    style="-fx-background-color: #c28d39; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;"
                    text="RESTORE"/>

            <Button fx:id="deleteButton" onAction="#handleDelete"
                    style="-fx-background-color: #710912; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;"
                    text="DELETE"/>

            <Button onAction="#handleClose"
                    style="-fx-background-color: #A5A5A5; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;"
                    text="CLOSE"/>
        </HBox>

    </children>
</VBox>
