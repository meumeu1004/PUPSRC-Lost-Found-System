<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="16"
      prefWidth="400" prefHeight="220"
      style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 5; -fx-border-radius: 5;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ArchiveReasonController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <!-- Header -->
    <Label text="Archive Item"
           style="-fx-font-weight: bold; -fx-font-size: 18px;"
           textFill="#710912"/>

    <Separator/>

    <!-- Reason dropdown -->
    <VBox spacing="6">
        <Label text="Reason for archiving:"
               style="-fx-font-weight: bold; -fx-font-size: 13px;"
               textFill="#5b5b5b"/>
        <ComboBox fx:id="reasonCombo"
                  maxWidth="Infinity"
                  style="-fx-background-color: #F4F4F4; -fx-border-color: #D3D3D3; -fx-border-radius: 5;"/>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="confirmButton"
                text="CONFIRM"
                onAction="#handleConfirm"
                style="-fx-background-color: #710912; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 5; -fx-cursor: hand; -fx-min-width: 90;"/>
        <Button text="CANCEL"
                onAction="#handleCancel"
                style="-fx-background-color: #A5A5A5; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 5; -fx-cursor: hand; -fx-min-width: 90;"/>
    </HBox>

</VBox>
