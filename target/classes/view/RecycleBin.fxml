<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.RecyclebinController"
      spacing="16" prefWidth="820" prefHeight="560"
      style="-fx-background-color: #FFFFFF; -fx-padding: 24;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="RECENTLY DELETED"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Close" onAction="#handleClose"
                style="-fx-background-color: #E0E0E0; -fx-border-radius: 5; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Subtitle -->
    <Label text="Deleted items are hidden from the UI but retained in the database."
           style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>

    <Separator/>

    <!-- Table -->
    <TableView fx:id="recycleBinTable" VBox.vgrow="ALWAYS"
               style="-fx-border-color: #E0E0E0;">
        <columns>
            <TableColumn fx:id="colId"       text="ID"            prefWidth="50"/>
            <TableColumn fx:id="colType"     text="Type"          prefWidth="70"/>
            <TableColumn fx:id="colName"     text="Item Name"     prefWidth="180"/>
            <TableColumn fx:id="colCategory" text="Category"      prefWidth="110"/>
            <TableColumn fx:id="colDate"     text="Date Reported" prefWidth="130"/>
            <TableColumn fx:id="colStatus"   text="Item Status"   prefWidth="110"/>
            <TableColumn fx:id="colAction"   text="Action"        prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="No deleted items found."
                   style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px;"/>
        </placeholder>
    </TableView>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="countLabel" text="0 deleted items"
               style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
    </HBox>

</VBox>