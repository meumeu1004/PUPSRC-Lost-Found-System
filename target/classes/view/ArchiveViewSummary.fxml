<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="dialogRoot" prefHeight="700.0" prefWidth="688.0" spacing="15.0"
      style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 5; -fx-border-radius: 5;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PostItemViewArchiveController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <!-- ── Header ── -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="titleLabel" style="-fx-font-weight: bold;" text="ITEM INFORMATION" textFill="#710912">
            <font><Font size="22.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-cursor: hand;"
                text="✕" textFill="#710912">
            <font><Font name="System Bold" size="18.0" /></font>
        </Button>
    </HBox>

    <Separator />

    <!-- ── Scrollable: Found Item Details ── -->
    <ScrollPane fitToWidth="true" prefHeight="280.0"
                style="-fx-background-color: transparent;" VBox.vgrow="NEVER">
        <content>
            <GridPane hgap="20.0" style="-fx-background-color: white;" vgap="12.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="35.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="65.0" />
                </columnConstraints>

                <!-- Left Column: Item Info -->
                <VBox spacing="8.0" GridPane.columnIndex="0">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;"
                           text="Item Information" textFill="#710912" />

                    <Label text="Item Name" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="itemNameField" editable="false"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 2 0 2 0; -fx-font-size: 13px;" />

                    <Label text="Category" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <ComboBox fx:id="categoryPicker" disable="true"
                              style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-opacity: 1; -fx-font-size: 13px;"
                              maxWidth="Infinity" />

                    <Label text="Color" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="colorField" editable="false"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 2 0 2 0; -fx-font-size: 13px;" />

                    <Label text="Item Type" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <Label fx:id="itemTypeLabel" text="—" textFill="#333333"
                           style="-fx-font-size: 13px;" />
                </VBox>

                <!-- Right Column: Report Info -->
                <VBox spacing="8.0" GridPane.columnIndex="1">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;"
                           text="Report Information" textFill="#710912" />

                    <Label text="Reported By" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="reporterNameField" editable="false"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 2 0 2 0; -fx-font-size: 13px;" />

                    <Label text="Contact Number" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="contactNumberField" editable="false"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 2 0 2 0; -fx-font-size: 13px;" />

                    <Label text="Email" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="emailField" editable="false"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 2 0 2 0; -fx-font-size: 13px;" />

                    <Label fx:id="itemDateLabel" text="Date" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <DatePicker fx:id="itemDatePicker" disable="true"
                                style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-opacity: 1; -fx-font-size: 13px;" />
                </VBox>

                <!-- Description -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                    <Label text="Description" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextArea fx:id="descArea" editable="false" prefHeight="70.0" wrapText="true"
                              style="-fx-control-inner-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent; -fx-font-size: 13px;" />
                </VBox>

                <!-- Item Image -->
                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                    <Label text="Item Image" textFill="#5b5b5b">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <HBox spacing="10.0" alignment="CENTER_LEFT"
                          style="-fx-border-color: #710912; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #FFF9F9; -fx-padding: 10;">
                        <Label fx:id="imagePlaceholderLabel" text="📷 No image provided" textFill="#710912">
                            <font><Font name="System Italic" size="12.0" /></font>
                        </Label>
                        <ImageView fx:id="previewImageView" fitHeight="90.0" fitWidth="120.0"
                                   preserveRatio="true" visible="false" />
                    </HBox>
                </VBox>

                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints minHeight="80.0" />
                    <RowConstraints minHeight="110.0" />
                </rowConstraints>
            </GridPane>
        </content>
    </ScrollPane>

    <!-- ── Scrollable: Archive + Claimant Info ── -->
    <ScrollPane fitToWidth="true" prefHeight="220.0" maxHeight="220.0"
                style="-fx-background-color: transparent; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;"
                VBox.vgrow="NEVER">
        <content>
            <VBox spacing="10.0"
                  style="-fx-background-color: #FFF9F9; -fx-border-radius: 5; -fx-background-radius: 5;">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>

                <!-- Archive Info -->
                <Label style="-fx-font-weight: bold; -fx-text-fill: #710912; -fx-font-size: 14px;"
                       text="ARCHIVE INFORMATION" />

                <HBox spacing="10.0">
                    <Label style="-fx-font-weight: bold;" text="Reason:" />
                    <Label fx:id="archiveReasonValue" text="—" textFill="#5b5b5b"
                           wrapText="true" maxWidth="480.0" />
                </HBox>
                <HBox spacing="10.0">
                    <Label style="-fx-font-weight: bold;" text="Archived On:" />
                    <Label fx:id="archivedAtValue" text="—" textFill="#5b5b5b" />
                </HBox>

                <!-- Divider + Claimant block — found items only -->
                <Separator fx:id="claimDivider" managed="false" visible="false" />

                <VBox fx:id="claimantInfoBlock" managed="false" visible="false" spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #710912; -fx-font-size: 14px;"
                           text="CLAIMANT INFORMATION" />

                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Full Name:" />
                        <Label fx:id="claimantNameValue" text="No Claimant" textFill="#5b5b5b" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Contact:" />
                        <Label fx:id="claimantContactValue" text="—" textFill="#5b5b5b" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Email:" />
                        <Label fx:id="claimantEmailValue" text="—" textFill="#5b5b5b"
                               wrapText="true" maxWidth="480.0" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Claim Date:" />
                        <Label fx:id="claimDateValue" text="Not Applicable" textFill="#5b5b5b" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Verified By:" />
                        <Label fx:id="verifiedByValue" text="Admin" textFill="#5b5b5b" />
                    </HBox>

                    <!-- Proof of Ownership Image -->
                    <HBox spacing="10.0" alignment="TOP_LEFT">
                        <Label style="-fx-font-weight: bold;" text="Proof of Ownership:" />
                        <VBox spacing="5.0">
                            <Label fx:id="proofPlaceholder" text="No proof image provided"
                                   textFill="#5b5b5b" style="-fx-font-style: italic;" />
                            <ImageView fx:id="proofImageView" fitHeight="150.0" fitWidth="200.0"
                                       preserveRatio="true" visible="false" />
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <Separator />

    <!-- ── Buttons ── -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">

        <!-- editButton MUST exist for handleClose() to work — hidden in summary view -->
        <Button fx:id="editButton" onAction="#handleEdit"
                managed="false" visible="false"
                style="-fx-background-color: #710912; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="EDIT" />

        <Button fx:id="markFoundButton" managed="false" visible="false"
                onAction="#handleMarkAsFound"
                style="-fx-background-color: #153240; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="✅ MARK AS FOUND" />

        <Button fx:id="claimButton" managed="false" visible="false"
                onAction="#handleClaim"
                style="-fx-background-color: #c28d39; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="CLAIM" />

        <Button fx:id="archiveButton" managed="false" visible="false"
                onAction="#handleArchive"
                style="-fx-background-color: #154230; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="ARCHIVE" />

        <Button fx:id="restoreButton" managed="false" visible="false"
                onAction="#handleRestore"
                style="-fx-background-color: #c28d39; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="🔄 RESTORE" />

        <Button fx:id="deleteButton" managed="false" visible="false"
                onAction="#handleDelete"
                style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="🗑 DELETE" />

        <Button onAction="#handleClose"
                style="-fx-background-color: #A5A5A5; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"
                text="CLOSE" />
    </HBox>

</VBox>
