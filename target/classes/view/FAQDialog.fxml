<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-border-color: #710912; -fx-border-width: 3; -fx-background-radius: 10; -fx-border-radius: 10;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FAQController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-weight: bold;" text="FREQUENTLY ASKED QUESTIONS" textFill="#710912">
                    <font><Font size="22.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;" text="✕" textFill="#710912"/>
            </children>
        </HBox>

        <Separator />

        <ScrollPane fitToWidth="true" prefHeight="500.0" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="15.0">
                    <children>
                        <!-- FAQ 1 - Internet Stability (NEW - placed at top) -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: Why can't I submit or perform any actions?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Please check your internet connection. The system requires a stable internet connection to communicate with the database. If you are connected, try refreshing the page or contact your system administrator." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 2 - Original Q1 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I report a lost item?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Click the 'POST LOST ITEM' button on the dashboard, fill out all required information including item name, category, color, and description. Then click 'SUBMIT REPORT'." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 3 - Original Q2 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I report a found item?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Click the 'POST FOUND ITEM' button on the dashboard, fill out all required information, and submit the report. The item will be listed as 'Found'." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 4 - Original Q3 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I claim an item?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Click on any 'Found' item card to view details, then click the 'CLAIM' button. You will need to provide your personal information and proof of ownership. Admin password is required to process the claim." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 5 - Original Q4 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: What happens after an item is claimed?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Once an item is claimed, it moves to the Archive section under 'Claimed' status. The item will no longer appear in the main dashboard." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 6 - Original Q5 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I search for items?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Use the search bar at the top of the dashboard to search by item name, description, or color. You can also filter by category and status." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 7 - Original Q6 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I edit an existing item?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Click on any item card, then click the 'EDIT' button. You will need to enter the admin password to enable edit mode. Once verified, you can modify all fields including status." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 8 - Original Q7 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I change my password?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: Click the settings icon (⚙️) in the top-right corner of the dashboard. Enter your current password, then your new password (minimum 6 characters with letters and numbers), and confirm." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 9 - Original Q8 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: What is the Archive section?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: The Archive section stores items that have been 'Claimed' or marked as 'Unresolved'. Click the 'ARCHIVE' button to toggle between the main dashboard and archive view." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 10 - Original Q9 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: How do I upload images for items?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: When creating or editing an item, click on the image upload area to select an image from your computer. The image will be displayed on the item card and in the item details." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- FAQ 11 - Original Q10 -->
                        <VBox spacing="5.0" style="-fx-background-color: #FFF9F9; -fx-border-color: #710912; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>
                                <Label text="Q: What contact information is visible to users?" style="-fx-font-weight: bold; -fx-text-fill: #710912;">
                                    <font><Font size="14.0" /></font>
                                </Label>
                                <Label text="A: For privacy protection, reporter contact information (name, phone, email) is hidden by default. This information only becomes visible after entering the admin password and enabling edit mode." textFill="#5b5b5b" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Separator />

        <Button fx:id="closeButton" onAction="#handleClose" style="-fx-background-color: #710912; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 30 10 30;" text="CLOSE" />
    </children>
</VBox>