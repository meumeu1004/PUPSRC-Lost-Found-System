<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefWidth="1280.0" style="-fx-background-color: #FFFFFF;" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminController">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" prefWidth="1297.0" spacing="15.0" style="-fx-background-color: #710912;">
                <padding>
                    <Insets left="20.0" right="40.0" />
                </padding>
                <ImageView fitHeight="50.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../media/logo_icon.png" />
                    <HBox.margin>
                        <Insets bottom="3.0" />
                    </HBox.margin>
                </ImageView>
                <Label prefHeight="26.0" prefWidth="450.0" style="-fx-text-fill: white;" styleClass="label-Logo" stylesheets="@../styles/style.css" text="LOST &amp; FOUND SYSTEM" textOverrun="CLIP" wrapText="true">
                    <font>
                        <Font name="Agency FB Bold" size="32.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleNeedHelp" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: white; -fx-font-size: 16px;" styleClass="hover-link" stylesheets="@../styles/style.css" text="Need Help?" />
                <Button onAction="#handleSettings" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <ImageView fitHeight="31.0" fitWidth="31.0">
                            <Image url="@../media/settings.png" />
                        </ImageView>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="614.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
            <VBox prefWidth="1280.0" spacing="25.0">
                <padding>
                    <Insets bottom="30.0" left="40.0" right="40.0" />
                </padding>

                <Label fx:id="dashboardTitleLabel" style="-fx-font-weight: 800; -fx-font-size: 30px; -fx-text-fill: #333333; -fx-padding: 0 0 -15 0;" text="Welcome to the Dashboard!">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>

                <HBox spacing="20.0">
                    <VBox alignment="CENTER" prefWidth="150.0" style="-fx-background-radius: 10;" styleClass="overview-lost" stylesheets="@../styles/style.css" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" top="20.0" /></padding>
                        <Label fx:id="totalLostLabel" style="-fx-font-weight: bold; -fx-font-size: 32px;" text="0" />
                        <Label fx:id="totalLostLabelText" style="-fx-font-size: 14px;" text="TOTAL LOST ITEMS" />
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="150.0" style="-fx-background-radius: 10;" styleClass="overview-found" stylesheets="@../styles/style.css" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" top="20.0" /></padding>
                        <Label fx:id="totalFoundLabel" style="-fx-font-weight: bold; -fx-font-size: 32px;" text="0" />
                        <Label fx:id="totalFoundLabelText" style="-fx-font-size: 14px;" text="TOTAL FOUND ITEMS" />
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="150.0" style="-fx-background-radius: 10;" styleClass="overview-archived" stylesheets="@../styles/style.css" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" top="20.0" /></padding>
                        <Label fx:id="totalUnresolvedLabel" style="-fx-font-weight: bold; -fx-font-size: 32px;" text="0" />
                        <Label style="-fx-font-size: 14px;" text="ARCHIVED ITEMS" />
                    </VBox>
                </HBox>

                <!-- BUTTONS SECTION - switches between normal and archive view -->
                <HBox spacing="20.0">
                    <!-- Normal View Buttons (visible by default) -->
                    <StackPane fx:id="normalPostLost" styleClass="action-button" HBox.hgrow="ALWAYS">
                        <Button maxHeight="60.0" maxWidth="Infinity" onAction="#handlePostLost" prefHeight="60.0" prefWidth="150.0" style="-fx-background-color: #c28d39; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" styleClass="action-button" text="POST LOST ITEM" />
                        <ImageView fitHeight="73.0" fitWidth="82.0" rotate="-18.4" StackPane.alignment="TOP_LEFT">
                            <Image url="@../media/questionmark.png" />
                        </ImageView>
                        <ImageView fitHeight="48.0" fitWidth="49.0" rotate="17.3" styleClass="action-button" StackPane.alignment="BOTTOM_RIGHT">
                            <Image url="@../media/questionmark.png" />
                        </ImageView>
                    </StackPane>

                    <StackPane fx:id="normalPostFound" styleClass="action-button" HBox.hgrow="ALWAYS">
                        <Button maxHeight="60.0" maxWidth="Infinity" onAction="#handlePostFound" prefHeight="60.0" prefWidth="150.0" style="-fx-background-color: #153240; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" styleClass="action-button" text="POST FOUND ITEM" />
                        <ImageView fitHeight="54.0" fitWidth="13.0" rotate="-11.3" StackPane.alignment="CENTER_LEFT">
                            <Image url="@../media/exclamation.png" />
                            <StackPane.margin><Insets left="10.0" /></StackPane.margin>
                        </ImageView>
                        <ImageView fitHeight="72.0" fitWidth="19.0" rotate="4.2" StackPane.alignment="TOP_LEFT">
                            <Image url="@../media/exclamation.png" />
                            <StackPane.margin><Insets left="40.0" /></StackPane.margin>
                        </ImageView>
                    </StackPane>

                    <StackPane fx:id="normalArchive" styleClass="action-button" HBox.hgrow="ALWAYS">
                        <Button fx:id="archiveButton" maxHeight="60.0" maxWidth="Infinity" onAction="#handleArchive" prefHeight="60.0" prefWidth="150.0" style="-fx-background-color: #154230; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" styleClass="action-button" text="ARCHIVE" />
                        <ImageView fitHeight="64.0" fitWidth="66.0" rotate="23.2" StackPane.alignment="CENTER_LEFT">
                            <Image url="@../media/archive.png" />
                        </ImageView>
                    </StackPane>

                    <!-- Archive View Buttons (hidden by default) -->
                    <StackPane fx:id="archiveBackToMain" styleClass="action-button" HBox.hgrow="ALWAYS" visible="false" managed="false">
                        <Button fx:id="backToMainButton" maxHeight="60.0" maxWidth="Infinity" onAction="#handleBackToMain" prefHeight="60.0" prefWidth="150.0" style="-fx-background-color: #154230; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" styleClass="action-button" text="BACK TO DASHBOARD" />
                        <ImageView fitHeight="64.0" fitWidth="66.0" rotate="23.2" StackPane.alignment="CENTER_LEFT">
                            <Image url="@../media/archive.png" />
                        </ImageView>
                    </StackPane>

                    <StackPane fx:id="archiveRecentlyDeleted" styleClass="action-button" HBox.hgrow="ALWAYS" visible="false" managed="false">
                        <Button fx:id="recentlyDeletedButton" maxHeight="60.0" maxWidth="Infinity" onAction="#handleRecentlyDeleted" prefHeight="60.0" prefWidth="150.0" style="-fx-background-color: #c28d39; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" styleClass="action-button" text="RECENTLY DELETED" />
                        <ImageView fitHeight="54.0" fitWidth="13.0" rotate="-11.3" StackPane.alignment="CENTER_LEFT">
                            <Image url="@../media/exclamation.png" />
                            <StackPane.margin><Insets left="10.0" /></StackPane.margin>
                        </ImageView>
                        <ImageView fitHeight="72.0" fitWidth="19.0" rotate="4.2" StackPane.alignment="TOP_LEFT">
                            <Image url="@../media/exclamation.png" />
                            <StackPane.margin><Insets left="40.0" /></StackPane.margin>
                        </ImageView>
                    </StackPane>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #710912; -fx-background-radius: 10;">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                    <ImageView fitHeight="28.0" fitWidth="26.0" rotate="-8.1">
                        <Image url="@../media/searchicon.png" />
                    </ImageView>
                    <TextField fx:id="searchField" onAction="#handleSearch" promptText="Search Item, Keywords..." style="-fx-background-radius: 5;" HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="sortCombo" prefWidth="140.0" promptText="Sort by" />
                    <ComboBox fx:id="categoryCombo" prefWidth="150.0" promptText="All Category" />
                    <ComboBox fx:id="typeCombo" prefWidth="150.0" promptText="All Type" />
                </HBox>

                <GridPane fx:id="itemGrid" hgap="25.0" vgap="25.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25.0" />
                        <ColumnConstraints percentWidth="25.0" />
                        <ColumnConstraints percentWidth="25.0" />
                        <ColumnConstraints percentWidth="25.0" />
                        <ColumnConstraints percentWidth="25.0" />
                    </columnConstraints>
                </GridPane>

                <HBox alignment="CENTER" spacing="15.0">
                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                    <Button fx:id="prevPageBtn" onAction="#handlePrevPage" style="-fx-background-color: #710912; -fx-cursor: hand; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 8 16 8 16; -fx-font-weight: bold;" text="◀ PREV" textFill="WHITE" />
                    <Label fx:id="pageLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #333333; -fx-min-width: 120; -fx-alignment: center;" text="Page 1 of 1" />
                    <Button fx:id="nextPageBtn" onAction="#handleNextPage" style="-fx-background-color: #710912; -fx-cursor: hand; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 8 16 8 16; -fx-font-weight: bold;" text="NEXT ▶" textFill="WHITE" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox fx:id="pageButtonsContainer" alignment="CENTER_RIGHT" spacing="10.0" />
                </HBox>

                <VBox spacing="0">
                    <Separator />
                    <HBox alignment="CENTER" prefWidth="1184.0" spacing="50.0" style="-fx-background-color: #710912;">
                        <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 18px;" text="Contact Us" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="📞 Phone: +1 (555) 123-4567" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="✉️ Email: support@lostandfound.com" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="📍 Address: 123 Campus Drive" />
                        </VBox>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 18px;" text="Quick Links" />
                            <Label fx:id="aboutUsLink" style="-fx-text-fill: #CCCCCC; -fx-cursor: hand; -fx-underline: true;" text="About Us" />
                            <Label fx:id="termsLink" style="-fx-text-fill: #CCCCCC; -fx-cursor: hand; -fx-underline: true;" text="Terms of Service" />
                            <Label fx:id="privacyLink" style="-fx-text-fill: #CCCCCC; -fx-cursor: hand; -fx-underline: true;" text="Privacy Policy" />
                        </VBox>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 18px;" text="Hours" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="Mon-Fri: 9AM - 6PM" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="Sat: 10AM - 4PM" />
                            <Label style="-fx-text-fill: #CCCCCC;" text="Sun: Closed" />
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER" prefHeight="40.0" style="-fx-background-color: #710912;">
                        <Label style="-fx-text-fill: #888888; -fx-font-size: 12px;" text="© 2026 Lost and Found System. All rights reserved." />
                    </HBox>
                </VBox>
            </VBox>
            <BorderPane.margin>
                <Insets />
            </BorderPane.margin>
        </ScrollPane>
    </center>
</BorderPane>